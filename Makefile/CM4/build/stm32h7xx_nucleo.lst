 120:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** /**
 121:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @brief  Configures LED GPIO.
 122:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @param  Led Specifies the Led to be configured.
 123:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *   This parameter can be one of following parameters:
 124:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED1
 125:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED2
 126:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED3
 127:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @retval BSP status
 128:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   */
 129:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** int32_t BSP_LED_Init(Led_TypeDef Led)
 130:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** {
 131:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   int32_t ret = BSP_ERROR_NONE;
 132:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   GPIO_InitTypeDef  gpio_init_structure;
 133:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** 
 134:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   if((Led != LED1) && (Led != LED2) && (Led != LED3))
 135:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   {
 136:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     ret = BSP_ERROR_WRONG_PARAM;
 137:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   }
 138:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   else
 139:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   {
 140:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     /* Enable the GPIO LED Clock */
 141:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     if(Led == LED1)
 142:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     {
 143:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****       LED1_GPIO_CLK_ENABLE();
 144:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     }
ARM GAS  /tmp/cchhOxxT.s 			page 4


 145:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     else if(Led == LED2)
 146:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     {
 147:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****       LED2_GPIO_CLK_ENABLE();
 148:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     }
 149:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     else
 150:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     {
 151:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****       LED3_GPIO_CLK_ENABLE();
 152:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     }
 153:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     /* Configure the GPIO_LED pin */
 154:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     gpio_init_structure.Pin   = LED_PIN[Led];
 155:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     gpio_init_structure.Mode  = GPIO_MODE_OUTPUT_PP;
 156:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     gpio_init_structure.Pull  = GPIO_NOPULL;
 157:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     gpio_init_structure.Speed = GPIO_SPEED_FREQ_VERY_HIGH;
 158:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** 
 159:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     HAL_GPIO_Init(LED_PORT[Led], &gpio_init_structure);
 160:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****     HAL_GPIO_WritePin(LED_PORT[Led], LED_PIN[Led], GPIO_PIN_RESET);
 161:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   }
 162:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** 
 163:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   return ret;
 164:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** }
