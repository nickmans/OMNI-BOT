 166:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** /**
 167:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @brief  DeInit LEDs.
 168:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @param  Led LED to be de-init.
 169:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *   This parameter can be one of the following values:
 170:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED1
 171:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED2
 172:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   *     @arg  LED3
 173:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @note Led DeInit does not disable the GPIO clock nor disable the Mfx
 174:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   * @retval BSP status
 175:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   */
 176:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** int32_t BSP_LED_DeInit(Led_TypeDef Led)
 177:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** {
 178:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   int32_t ret = BSP_ERROR_NONE;
 179:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   GPIO_InitTypeDef  gpio_init_structure;
 180:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c **** 
 181:../../Drivers/BSP/STM32H7xx_Nucleo/stm32h7xx_nucleo.c ****   if((Led != LED1) && (Led != LED2) && (Led != LED3))
