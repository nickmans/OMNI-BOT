  38:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_eth.c ****       (#)Initialize the ETH low level resources through the HAL_ETH_MspInit() API:
  39:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_eth.c ****           (##) Enable the Ethernet interface clock using
  40:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_eth.c ****                 (+++)  __HAL_RCC_ETH1MAC_CLK_ENABLE()
  41:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_eth.c ****                 (+++)  __HAL_RCC_ETH1TX_CLK_ENABLE()
  42:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_eth.c ****                 (+++)  __HAL_RCC_ETH1RX_CLK_ENABLE()
